Operation                           Ruby code         Racket code
---------------------------------------------------------------------------
number addition                     1+2+3             (+ 1 2 3)
create array                        [1, 2, 3]         (vector 1 2 3)
create hash                         {a: 1, b: 2, c: 3}(hash 'a 1 'b 2)
create array of a range of numbers  Array(1..5)       (build-list 5 values)
create array of duplication elementsArray.new(3, 1)   (make-list 3 1)

Ming code                    Racket code
----------------------------------------------------------------
(双 'a 'b)                    (cons 'a 'b)
(􏿴 'a 'b 'c 'd)              (list 'a 'b 'c 'd)
(􏿝 '(1) '(2) '(3 4) '(5 6))  (append '(1) '(2) '(3 4) '(5 6))
(􏿜 '(1) '(2) '(3 4) '((5 6)))(append* '(1) '(2) '(3 4) '((5 6)))
(􏼓 6 'foo)                   (make-list 6 'foo)
(􏼎 10 並)                     (build-list 10 values)
(弓 '(a b c d e c f) 'c)      (index-of '(a b c d e c f) 'c)
(􏼏 10)                       (range 10)
(􏻿 'a 'b 'c 'd)              (vector 'a 'b 'c 'd)
(􏿰 'a 'b 'c 'd)              (hash 'a 'b 'c 'd)

